# Copy to `.env.local` (not committed).

# External HR API (browser `apiFetch` + server auth BFF). No trailing slash.
# Example: http://localhost:5000 — attendance uses GET /api/attendance/admin/all (needs attendance:read on token).
# Local deltadb (must include new /api/hrm routes): http://localhost:5000
# Production (only after HRM API is deployed): https://api.realtechmktg.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Optional: server-only upstream URL for `/api/auth/*` and `/api/hrm/*` BFF proxies.
API_BASE_URL=http://localhost:5000
